<script>
  const bellItems = document.querySelectorAll('#notiContent .bell-item');
  const ticker = document.getElementById('tickerInner');
  let html = '';
  bellItems.forEach(item => {
    html += `<span class="ticker-item">${item.innerHTML}</span><span class="ticker-sep">◆</span>`;
  });
  ticker.innerHTML = html + html;
  ticker.addEventListener('touchstart', () => ticker.style.animationPlayState = 'paused');
  ticker.addEventListener('touchend', () => ticker.style.animationPlayState = 'running');
</script>
